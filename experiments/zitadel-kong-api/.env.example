# Copy to .env and adjust if your Zitadel runs elsewhere.
# Defaults match the local iam/zitadel stack (Traefik on host port 8080).

# The exact issuer string Zitadel stamps into the token's `iss` claim.
# For the local stack this is http://localhost:8080 — must match BYTE-FOR-BYTE.
ZITADEL_ISSUER=http://localhost:8080

# How the kong-init container reaches Zitadel to download the JWKS.
# Containers can't use "localhost" to reach the host, so we go via the gateway.
ZITADEL_INTERNAL_URL=http://host.docker.internal:8080

# Zitadel sits behind Traefik with a Host(`localhost`) routing rule, so the
# JWKS request must carry this Host header even though we dial host.docker.internal.
ZITADEL_HOST_HEADER=localhost

# Kong's upstream (rendered into kong.yml as {{ .Upstream }}).
# Single host (default): the api container's DNS name on the shared `edge` network.
# Multi-host over NetBird: the API's NetBird IP or DNS name (see README → Multi-host).
# API_UPSTREAM=http://api:8000
# API_UPSTREAM=http://apihost.netbird.cloud:8000

# Multi-host only: on the API host, the NetBird IP to bind the API to, consumed
# by api/docker-compose.netbird.yml. Get it from `netbird status`.
# API_NETBIRD_IP=100.92.0.5

# ---- Only needed by `zk token` for the curl demo (not by Kong) ----
# Pick ONE credential style.
#
# A) Private Key JWT (recommended). Service user (type "serviceaccount") key,
#    saved as config/service-key.json.
ZITADEL_KEY_FILE=./config/service-key.json
#
# B) Client secret (machine user with a generated secret):
# ZITADEL_CLIENT_ID=...
# ZITADEL_CLIENT_SECRET=...
